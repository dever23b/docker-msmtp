#!/usr/bin/with-contenv bash
# spellcheck shell=bash

echo "[init-msmtp] Configuring MSMTP..."

# create log files
if [[ ! -f /config/log/msmtp.log ]]; then
  touch /config/log/msmtp.log
fi

if [[ ! -d /config/log/msmtpd ]]; then
  mkdir /config/log/msmtpd
fi

if [[ ! -f /config/log/msmtpd.log ]]; then
  ln -sf msmtpd/current /config/log/msmtpd.log
fi

# create config
if [[ ! -f /config/msmtp.conf ]]; then
  cp /defaults/msmtp.conf /config/msmtp.conf
fi
